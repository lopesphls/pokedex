<%- include('partials/header') %>
<main>
  <div class="container">
    <h1 class="title"><span></span> Catalogo</h1>
    <span class="linha"></span>
    <section class="favoritos">
      <% pokedex.forEach(pet => { %>
      <div class="box-update">
        <h3 class="texto-update"><%= pet.nome %></h3>
        <span></span>
        <img src="<%= pet.img %>" alt="" />
        <div class="btn">
          <span class="linha"></span>
          <input type="button" value="editar" src="#" />
          <input type="button" value="excluir" src="#" />
        </div>
      </div>
      <% }); %>
    </section>
</main>
<%- include("partials/footer") %>
